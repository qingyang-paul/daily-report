# --- Worspace: 工作区基础配置 ---
# 建议使用绝对路径，例如 /Users/yourname/.daily-info/
WORKSPACE_PATH="~/.daily-info/"
API_RESULTS_DIR="api_results/"
PARSED_RESULTS_DIR="parsed_results/"
EMAIL_HTML_DIR="email_outputs"
EMAIL_PDF_DIR="report_pdf"
REPORT_PDF_DIR="reports/"

# --- Email: 邮件内容数量限制 ---
GITHUB_TRENDING_TODAY_LIMIT=10
HUGGING_FACE_DAILY_PAPERS_LIMIT=10
OPENROUTER_LATEST_LLMS_LIMIT=5
OPENROUTER_TRENDING_APPS_LIMIT=5
PRODUCT_HUNT_APPS_LIMIT=5
HACKER_NEWS_POSTS_LIMIT=10
ARXIV_PAPERS_LIMIT=10
DEFAULT_SECTION_LIMIT=10

# --- Proxy: 网络代理配置 (可选) ---
# 格式: user:pass@host:port 或 host:port
WEBSHARE_PROXY1=""
WEBSHARE_PROXY2=""
WEBSHARE_PROXY3=""

# --- Product Hunt API 配置 ---
# 从 Product Hunt Dashboard 获取
Product_Hunt_API_Key="your_api_key_here"
Product_Hunt_API_Secret="your_api_secret_here"
Product_Hunt_Developer_Token="your_developer_token_here"

# --- RapidAPI 配置 (可选，如需采集 Twitter 等) ---
rapidapi-key="your_rapidapi_key_here"
rapidapi-twitter-host="twitter241.p.rapidapi.com"

# --- Resend: 邮件服务配置 ---
# 显示的发件人名称 (例如: AI Trend Assistant)
BOT_DISPLAY_NAME="Daily AI Insights"
# 邮箱前缀 (例如: report)
EMAIL_PREFIX="report"
# 已在 Resend 验证的域名 (例如: example.com)
EMAIL_DOMAIN="yourdomain.com"
# Resend API Key (以 re_ 开头)
RESEND_API_KEY="re_your_resend_key_here"

# --- Recipients: 接收者配置 ---
# 多个邮箱用英文逗号(,)隔开
RECEIVER_EMAILS="recipient1@example.com,recipient2@example.com"

# --- GitHub: 基础配置 ---
# 用于获取更准确的 Star/Fork 数据，建议提供只读 Token
GITHUB_READ_ONLY_ACCESS_KEY="your_github_pat_here"
